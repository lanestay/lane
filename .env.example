# Docker Compose environment variables
#
# Copy to .env:  cp .env.example .env
# Fill in the passwords below before starting.

# Database and storage passwords — change these before deploying
MSSQL_SA_PASSWORD=
POSTGRES_PASSWORD=
CLICKHOUSE_PASSWORD=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Auth — Tailscale is recommended for secure access without exposing ports.
# With tailscale, users are identified by their Tailscale login and the server
# binds to 127.0.0.1 (accessible only via your tailnet).
LANE_AUTH=email,tailscale
# Host-side bind address for Docker port mapping (default: 127.0.0.1).
# The binary inside the container always binds to 0.0.0.0 (set in Dockerfile).
# Set to 0.0.0.0 here only if you need to expose the port beyond localhost.
# LANE_BIND=127.0.0.1
# LANE_LOG_LEVEL=info,lane=debug

# OIDC providers (required when google/microsoft/github are in LANE_AUTH)
# LANE_BASE_URL=https://your-app.example.com
# LANE_GOOGLE_CLIENT_ID=
# LANE_GOOGLE_CLIENT_SECRET=
# LANE_MICROSOFT_CLIENT_ID=
# LANE_MICROSOFT_CLIENT_SECRET=
# LANE_GITHUB_CLIENT_ID=
# LANE_GITHUB_CLIENT_SECRET=

# Email code login (optional — enabled when SMTP_HOST is set)
# Users can sign in with a 6-digit code sent to their email instead of a password.
# Works with any SMTP provider (Gmail, SendGrid, AWS SES, etc.)
# For local testing, uncomment the mailpit service in docker-compose.full.yml
# LANE_SMTP_HOST=smtp.gmail.com
# LANE_SMTP_PORT=587
# LANE_SMTP_TLS=starttls
# LANE_SMTP_FROM=noreply@yourdomain.com
# LANE_SMTP_USERNAME=
# LANE_SMTP_PASSWORD=
